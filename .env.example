# Copia este archivo como `.env` y ajusta los valores.
# Los scripts de arranque (iniciar-windows.bat / iniciar-mac-linux.sh) crean
# un .env automáticamente si no existe.

# Ruta de la base de datos SQLite (archivo local).
DATABASE_URL="file:./prisma/dev.db"

# Secreto para firmar los JWT de NextAuth. Cámbialo por una frase larga y única.
# NextAuth v5 usa AUTH_SECRET; se acepta NEXTAUTH_SECRET por compatibilidad.
NEXTAUTH_SECRET="cambia-esto-por-una-frase-secreta-larga-y-unica"
AUTH_SECRET="cambia-esto-por-una-frase-secreta-larga-y-unica"

# URL base de la aplicación. En la red local usa la IP del servidor para que
# las tablets puedan iniciar sesión, p. ej. http://192.168.1.50:3001
NEXTAUTH_URL="http://localhost:3001"
AUTH_URL="http://localhost:3001"
